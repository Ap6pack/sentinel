# SENTINEL environment configuration
# Copy to .env and fill in values before running
# Never commit .env to git

# ── Required ─────────────────────────────────────────────────────────────────

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SENTINEL_JWT_SECRET=

# Get free token at: https://ion.cesium.com/
VITE_CESIUM_TOKEN=

# Get from: https://www.anthropic.com/
ANTHROPIC_API_KEY=

# ── Optional — defaults shown ─────────────────────────────────────────────────

SENTINEL_ADMIN_USERNAME=admin
SENTINEL_ADMIN_PASSWORD=admin
SENTINEL_LOG_LEVEL=INFO
SENTINEL_PORT=8080

# Redis (auto-configured in Docker)
SENTINEL_REDIS_URL=redis://localhost:6379

# Postgres (only needed with --profile history or full)
SENTINEL_POSTGRES_URL=postgresql+asyncpg://sentinel:sentinel@localhost:5432/sentinel
PGDATA_PATH=./pgdata

# RF layer
SENTINEL_RF_MOCK=false
SENTINEL_ADSB_DEVICE_INDEX=0
SENTINEL_AIS_DEVICE_INDEX=1

# OSINT layer — all optional, collectors skip gracefully if missing
SENTINEL_WIGLE_API_KEY=
SENTINEL_STRAVA_CLIENT_ID=
SENTINEL_STRAVA_CLIENT_SECRET=
SENTINEL_SHODAN_API_KEY=
SENTINEL_ADSB_HISTORY_API_KEY=
SENTINEL_HUNTER_API_KEY=
SENTINEL_GOOGLE_PLACES_API_KEY=

# AI layer
SENTINEL_AI_MAX_CALLS_PER_HOUR=100

# Viz layer (also set in packages/sentinel-viz/.env.local)
VITE_WS_URL=ws://localhost:8080/ws/stream
VITE_OSINT_API=http://localhost:8080/api/osint